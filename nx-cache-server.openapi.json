{
  "openapi": "3.0.0",
  "info": {
    "title": "Nx custom remote cache specification.",
    "description": "Nx is an AI-first build platform that connects everything from your editor to CI. Helping you deliver fast, without breaking things.",
    "version": "1.0.0"
  },
  "paths": {
    "/health": {
      "get": {
        "description": "Lightweight unauthenticated health check for container and orchestrator probes. Returns OK when the server process is running and accepting requests; it does not validate token DB or storage backend reachability.",
        "operationId": "getHealth",
        "security": [],
        "responses": {
          "200": {
            "description": "Server is running",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "OK"
                }
              }
            }
          }
        }
      }
    },
    "/ready": {
      "get": {
        "description": "Deep unauthenticated readiness check for deployment probes. Returns OK only when the token database and configured cache storage pass their readiness checks.",
        "operationId": "getReady",
        "security": [],
        "responses": {
          "200": {
            "description": "Dependencies are ready",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "OK"
                }
              }
            }
          },
          "503": {
            "description": "Token storage or cache storage is not ready",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "Not Ready"
                }
              }
            }
          }
        }
      }
    },
    "/metrics": {
      "get": {
        "description": "Prometheus metrics in the text exposition format (version 0.0.4). Unauthenticated and meant to be scraped over a private network; restrict it to your metrics collector and never expose it publicly. Reports cache request counters by method and result (the GET hit/miss split is the cache hit-rate, and PUT 'forbidden' includes writes rejected for missing, invalid, or readonly tokens), total bytes accepted by successful uploads, filesystem eviction counters (nx_cache_evicted_entries_total and nx_cache_evicted_bytes_total), and the latest filesystem cache size gauge (nx_cache_size_bytes).",
        "operationId": "getMetrics",
        "security": [],
        "responses": {
          "200": {
            "description": "Prometheus exposition-format metrics",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/v1/cache/{hash}": {
      "put": {
        "description": "Upload a task output",
        "operationId": "put",
        "security": [
          {
            "bearerToken": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully uploaded the output"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "403": {
            "description": "Access forbidden. (e.g. read-only token used to write)",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "description": "Error message provided to the Nx CLI user"
                }
              }
            }
          },
          "409": {
            "description": "Cannot override an existing record",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/PlainTextError"
                }
              }
            }
          },
          "413": {
            "$ref": "#/components/responses/PayloadTooLarge"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        },
        "parameters": [
          {
            "in": "header",
            "description": "The file size in bytes",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            },
            "name": "Content-Length"
          },
          {
            "name": "hash",
            "description": "The task hash corresponding to the uploaded task output",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        }
      },
      "get": {
        "description": "Download a task output (cache artifact) for the given task hash.",
        "operationId": "get",
        "security": [
          {
            "bearerToken": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved cache artifact",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary",
                  "description": "An octet stream with the content."
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "403": {
            "$ref": "#/components/responses/AccessForbidden"
          },
          "404": {
            "description": "The record was not found",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        },
        "parameters": [
          {
            "name": "hash",
            "description": "The task hash corresponding to the cache artifact to download.",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/v1/admin/tokens": {
      "get": {
        "description": "List all configured API tokens. Requires the ADMIN_TOKEN bearer token.",
        "operationId": "adminListTokens",
        "security": [
          {
            "bearerToken": []
          }
        ],
        "responses": {
          "200": {
            "description": "A list of tokens. Token values are omitted; they are stored hashed and cannot be recovered.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListTokensResponse"
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/AccessForbidden"
          }
        }
      },
      "post": {
        "description": "Create a new API token. Requires the ADMIN_TOKEN bearer token.",
        "operationId": "adminAddToken",
        "security": [
          {
            "bearerToken": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddTokenRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The created token record. This response includes the full, unmasked token value; store it securely.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenRecord"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "403": {
            "$ref": "#/components/responses/AccessForbidden"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/v1/admin/tokens/{id}": {
      "delete": {
        "description": "Delete a token by its id. Requires the ADMIN_TOKEN bearer token. Deleting by id (never by value) keeps token values out of URLs and access logs, and lets an admin revoke a token whose value has been lost.",
        "operationId": "adminDeleteToken",
        "security": [
          {
            "bearerToken": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The id of the token to delete, as returned by the list endpoint.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Token deleted"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "403": {
            "$ref": "#/components/responses/AccessForbidden"
          },
          "404": {
            "description": "Token not found",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerToken": {
        "type": "http",
        "description": "Send an Authorization header with a Bearer token. For cache endpoints, use a token stored in the server database (permission 'readonly' or 'full'). For admin endpoints, use the ADMIN_TOKEN configured via environment variable.",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "TokenPermission": {
        "type": "string",
        "enum": ["readonly", "full"],
        "description": "Token permission. 'readonly' can download cache entries; 'full' can download and upload cache entries."
      },
      "TokenRecord": {
        "type": "object",
        "required": ["id", "value", "permission"],
        "properties": {
          "id": {
            "type": "string",
            "description": "A human-friendly identifier for the token (e.g. a CI system name)."
          },
          "value": {
            "type": "string",
            "description": "The token value. Returned only when creating a token; absent from list responses."
          },
          "permission": {
            "$ref": "#/components/schemas/TokenPermission"
          }
        }
      },
      "TokenSummary": {
        "type": "object",
        "required": ["id", "permission"],
        "properties": {
          "id": {
            "type": "string",
            "description": "A human-friendly identifier for the token (e.g. a CI system name)."
          },
          "permission": {
            "$ref": "#/components/schemas/TokenPermission"
          }
        }
      },
      "AddTokenRequest": {
        "type": "object",
        "required": ["id", "permission"],
        "properties": {
          "id": {
            "type": "string"
          },
          "permission": {
            "$ref": "#/components/schemas/TokenPermission"
          }
        }
      },
      "ListTokensResponse": {
        "type": "object",
        "required": ["tokens"],
        "properties": {
          "tokens": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TokenSummary"
            }
          }
        }
      },
      "PlainTextError": {
        "type": "string",
        "description": "Plain-text error message."
      }
    },
    "responses": {
      "AccessForbidden": {
        "description": "Access forbidden",
        "content": {
          "text/plain": {
            "schema": {
              "$ref": "#/components/schemas/PlainTextError"
            }
          }
        }
      },
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "text/plain": {
            "schema": {
              "$ref": "#/components/schemas/PlainTextError"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflict — the token id or value already exists",
        "content": {
          "text/plain": {
            "schema": {
              "$ref": "#/components/schemas/PlainTextError"
            }
          }
        }
      },
      "InternalServerError": {
        "description": "Unexpected server-side failure (storage or database error). The body is a plain-text error message.",
        "content": {
          "text/plain": {
            "schema": {
              "$ref": "#/components/schemas/PlainTextError"
            }
          }
        }
      },
      "PayloadTooLarge": {
        "description": "Payload too large",
        "content": {
          "text/plain": {
            "schema": {
              "$ref": "#/components/schemas/PlainTextError"
            }
          }
        }
      }
    }
  }
}
